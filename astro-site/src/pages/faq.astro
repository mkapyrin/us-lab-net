---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: "What's your return policy?",
    a: "Return of most of our products is limited to trial period, established by copyright owner. After this period all licenses are non-returnable.",
    accent: 'cyan',
  },
  {
    q: "Do you ship oversees and to P.O. boxes?",
    a: "Yes, we ship electronically anywhere in the Universe with limitations according to US Law and technical availability.",
    accent: 'magenta',
  },
  {
    q: "Do you have customer service?",
    a: "Of course! Our friendly and knowledgeable customer services reps are available by email to answer your questions 24/7/365.",
    accent: 'purple',
  },
];
---

<Layout title="Frequently Asked Questions (FAQ) – US-Lab, Inc. Software logistics & development" pageTitle="FAQ">

  <!-- ===== INTRO ===== -->
  <section class="section-pad-sm">
    <div class="container">
      <div class="faq-intro glass-card">
        <div class="faq-intro-glow"></div>
        <p class="section-label" style="margin-bottom: 0.75rem;">About Software Licensing</p>
        <h2 class="neon-heading" style="font-size: clamp(1.5rem, 3vw, 2.2rem); margin-bottom: 1.25rem;">
          Understanding Software Licences
        </h2>
        <p style="color: var(--text-dim); max-width: 760px; line-height: 1.8; font-size: 0.975rem;">
          A software license is a legal instrument (usually by way of contract law, with or without printed material) governing the use or redistribution of software. Under United States copyright law, all software is copyright protected, in both source code and object code forms. The only exception is software in the public domain. A typical software license grants the licensee, typically an end-user, permission to use one or more copies of software in ways where such a use would otherwise potentially constitute copyright infringement of the software owner's exclusive rights under copyright.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ACCORDION ===== -->
  <section class="section-pad-sm">
    <div class="container">
      <div class="section-header" style="margin-bottom: 2.5rem;">
        <p class="section-label">Common Questions</p>
        <h2 class="neon-heading" style="font-size: clamp(1.6rem, 3vw, 2.2rem);">Frequently Asked Questions</h2>
        <div class="neon-divider"></div>
      </div>

      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class={`faq-item glass-card faq-${faq.accent}`} id={`faq-${i}`}>
            <summary class="faq-summary">
              <span class="faq-q">{faq.q}</span>
              <span class="faq-chevron" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <path d="M4 6l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </summary>
            <div class="faq-answer">
              <p>{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CONTACT CTA ===== -->
  <section class="section-pad-sm">
    <div class="container">
      <div class="faq-cta glass-card">
        <div class="faq-cta-glow"></div>
        <h2 class="neon-heading" style="font-size: clamp(1.3rem, 2.5vw, 1.8rem); margin-bottom: 0.75rem;">
          Still have questions?
        </h2>
        <p style="color: var(--text-dim); max-width: 440px; margin: 0 auto 1.75rem;">
          Our friendly team is available 24/7 by email. We'll get back to you as soon as possible.
        </p>
        <a href="/contact" class="btn-primary">Get In Touch</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ===== INTRO ===== */
  .faq-intro {
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }

  .faq-intro-glow {
    position: absolute;
    top: -80px; right: -80px;
    width: 280px; height: 280px;
    background: radial-gradient(circle, rgba(123,47,247,0.08), transparent 70%);
    pointer-events: none;
  }

  /* ===== FAQ ACCORDION ===== */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    padding: 0;
    overflow: hidden;
    cursor: pointer;
  }

  .faq-item[open] {
    background: var(--glass-bg2) !important;
  }

  .faq-cyan[open]    { border-color: rgba(0,240,255,0.3) !important; }
  .faq-magenta[open] { border-color: rgba(247,37,133,0.3) !important; }
  .faq-purple[open]  { border-color: rgba(123,47,247,0.3) !important; }

  .faq-summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    gap: 1rem;
    user-select: none;
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary::marker {
    display: none;
  }

  .faq-q {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--white);
    flex: 1;
  }

  .faq-chevron {
    flex-shrink: 0;
    transition: transform 0.3s, color 0.2s;
    color: var(--text-dim);
  }

  .faq-cyan    .faq-chevron { color: var(--cyan); }
  .faq-magenta .faq-chevron { color: var(--magenta2); }
  .faq-purple  .faq-chevron { color: #a855f7; }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 2rem 1.75rem;
    border-top: 1px solid var(--glass-border);
  }

  .faq-answer p {
    color: var(--text-dim);
    font-size: 0.975rem;
    line-height: 1.75;
    padding-top: 1.25rem;
  }

  .faq-item:hover .faq-q {
    color: var(--white);
  }

  /* ===== CONTACT CTA ===== */
  .faq-cta {
    text-align: center;
    padding: 3rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .faq-cta-glow {
    position: absolute;
    bottom: -60px; left: 50%;
    transform: translateX(-50%);
    width: 250px; height: 250px;
    background: radial-gradient(circle, rgba(0,240,255,0.06), transparent 70%);
    pointer-events: none;
  }
</style>
